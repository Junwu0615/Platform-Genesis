{
  "name": "mqtt-cp-mach-order",
  "config": {
    "connector.class": "io.confluent.connect.mqtt.MqttSourceConnector",
    "confluent.topic.bootstrap.servers": "ooud-cluster-kafka-1:29092",
    "confluent.index.bootstrap.servers": "ooud-cluster-kafka-1:29092",
    "mqtt.server.uri": "tcp://ooud-cluster-mqtt-1:1883",
    "mqtt.username": "admin",
    "mqtt.password": "123456789",


    "tasks.max": "1",
    "mqtt.qos": "0",
    "mqtt.clean.session.exists": "true",
    "value.converter.schemas.enable": "false",
    "confluent.topic.replication.factor": "1",
    "confluent.license.topic.replication.factor": "1",


    "mqtt.topics": "cp/mach-order/+",
    "kafka.topic": "mqtt_raw.cp.mach-order",


    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.converters.ByteArrayConverter",
    "mqtt.record.processor.class": "io.confluent.connect.mqtt.processor.RawMessageProcessor"
  }
}