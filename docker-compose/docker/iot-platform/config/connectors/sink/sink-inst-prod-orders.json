{
  "name": "sink-inst-prod-orders",
  "config": {
    "connector.class": "io.confluent.connect.jdbc.JdbcSinkConnector",
    "connection.url": "jdbc:postgresql://dev-db:5432/pgdatabase",
    "connection.user": "olap_user",
    "connection.password": "olap_pwd",
    "auto.create": "false",
    "auto.evolve": "false",

    "tasks.max": "3",

    "topics": "inst.prod-orders",
    "table.name.format": "oltp.production_orders",

    "insert.mode": "update",
    "pk.mode": "record_value",
    "pk.fields": "order_id",

    "key.converter.schemas.enable": "false",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "true",

    "transforms": "ReplaceField",
    "transforms.ReplaceField.type": "org.apache.kafka.connect.transforms.ReplaceField$Value",
    "transforms.ReplaceField.whitelist": "order_id,start_at,end_at"
  }
}