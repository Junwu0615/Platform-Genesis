{
  "name": "sink-inst-status-logs",
  "config": {
    "connector.class": "io.confluent.connect.jdbc.JdbcSinkConnector",
    "connection.url": "jdbc:postgresql://dev-db:5432/pgdatabase",
    "connection.user": "olap_user",
    "connection.password": "olap_pwd",

    "tasks.max": "3",

    "topics": "inst.status-logs",
    "insert.mode": "upsert",

    "table.name.format": "oltp.machine_status_logs",

    "transforms": "",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",

    "auto.create": "false",
    "auto.evolve": "false"
  }
}